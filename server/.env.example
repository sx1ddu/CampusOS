# Copy this file to .env and fill in real values before running the app.

NODE_ENV=development
PORT=5000

# MongoDB connection string used by the running application.
MONGO_URI=mongodb://127.0.0.1:27017/campusos_dev

# Separate URI for the seed script so you can seed a scratch database
# without touching your main dev database. Defaults to MONGO_URI if unset.
SEED_MONGO_URI=mongodb://127.0.0.1:27017/campusos_dev

# Used for signing auth tokens. MUST be set to a long random value in
# production — the app will refuse to boot in production without it.
JWT_SECRET=dev-only-insecure-secret-change-me
JWT_EXPIRES_IN=7d

# Comma-separated list of allowed student email domains for registration,
# e.g. "iith.ac.in,bits-pilani.ac.in". Leave empty in local development to
# allow any email domain.
ALLOWED_COLLEGE_DOMAINS=

LOG_LEVEL=debug
